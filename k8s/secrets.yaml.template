apiVersion: v1
kind: Secret
metadata:
  name: ai-debugger-llm-secrets
  namespace: ai-debugger
type: Opaque
stringData:
  # Replace with your actual values
  LLM_PROVIDER: "openai"  # or "mock"
  OPENAI_API_KEY: "your-openai-api-key-here"
  OPENAI_MODEL: "gpt-4o-mini"
  LLM_TIMEOUT: "15"
  LLM_MAX_TOKENS: "500"
